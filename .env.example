# Required when deploying this repository directly to Cloudflare Workers.
# Create the database in Cloudflare D1, then set its UUID in Cloudflare's build variables.
D1_DATABASE_ID=
D1_DATABASE_NAME=burtbaptistchurch

# Staff portal bootstrap values. Set these as Cloudflare secrets; never commit values.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
